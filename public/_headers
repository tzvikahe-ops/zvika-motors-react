/*
 * Cache-Control headers for static assets.
 * Works with Netlify, Vercel reads _headers too.
 * Lovable's hosting respects this file format.
 */

# Immutable hashed assets (JS, CSS, images built by Vite)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# WebP images in public/
/*.webp
  Cache-Control: public, max-age=31536000, immutable

# SVG assets
/*.svg
  Cache-Control: public, max-age=31536000, immutable

# Fonts
/assets/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# HTML — always revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Root
/
  Cache-Control: public, max-age=0, must-revalidate
