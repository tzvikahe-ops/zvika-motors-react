/*
 * Cache-Control headers for static assets.
 * Works with Netlify, Vercel reads _headers too.
 * Lovable's hosting respects this file format.
 */

# Immutable hashed assets (JS, CSS, images built by Vite)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# WebP images in public/
/*.webp
  Cache-Control: public, max-age=31536000, immutable

# SVG assets
/*.svg
  Cache-Control: public, max-age=31536000, immutable

# Fonts
/assets/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# HTML — always revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Root
/
  Cache-Control: public, max-age=0, must-revalidate

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://www.google.com https://www.gstatic.com https://cdn.enable.co.il; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://images.unsplash.com https://pub-bb2e103a32db4e198524a2e9ed8f35b4.r2.dev https://www.google.com https://maps.gstatic.com https://maps.googleapis.com https://www.gstatic.com https://lh3.googleusercontent.com; connect-src 'self' https://*.supabase.co https://www.google-analytics.com https://analytics.google.com https://www.googletagmanager.com https://featurable.com; frame-src https://www.google.com; form-action 'self'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests;
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()