# Canonical domain: non-www → www (301 permanent)
https://ortzat.co.il/* https://www.ortzat.co.il/:splat 301!

# 301 redirects: /index.html → clean URL (prevents duplicate content if old links exist)
/services/index.html /services 301
/about/index.html /about 301
/gallery/index.html /gallery 301
/contact/index.html /contact 301
/faq/index.html /faq 301
/blog/index.html /blog 301
/privacy/index.html /privacy 301
/accessibility/index.html /accessibility 301

# Blog article routes
/blog/:slug/index.html /blog/:slug 301
/blog/:slug /blog/:slug.html 200

